STRAPI_URL=http://localhost:1337
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
# Read-only token for Next.js (local: kbng-local-read / prod: frontend-read)
STRAPI_API_TOKEN=your_strapi_read_token
# Full-access token for seed scripts (prod: kbng-seed-write)
STRAPI_SEED_TOKEN=your_strapi_seed_token
STRAPI_REVALIDATE_SECONDS=60

# Pairing:
# - Local:  .env.local            → http://localhost:1337
# - Prod:   .env.production.local → https://….strapiapp.com (and Netlify env)
